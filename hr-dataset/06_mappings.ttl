# =============================================================================
# Local -> Global SKOS mappings, with provenance
#
# Every mapping link has an associated prov:Activity that records:
#   - who created the mapping
#   - when
#   - what method (LLM-drafted, human-approved, manual, rule-based)
#   - confidence score in [0,1]
#   - review status (approved, in-review, draft)
#
# Two mappings are deliberately given LOW confidence (< 0.7) so they appear
# in the "mappings needing review" diagnostic query.
# =============================================================================

@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:   <http://www.w3.org/ns/prov#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix acme:   <https://acme.example/ontology/> .
@prefix acmeG:  <https://acme.example/global/role/> .
@prefix acmeUK: <https://acme.example/uk/role/> .
@prefix acmeDE: <https://acme.example/de/role/> .
@prefix acmeUS: <https://acme.example/us/role/> .
@prefix mapAct: <https://acme.example/mapping/activity/> .

# Mapping "agents" (curators)
<https://acme.example/person/jordan-kim> a prov:Person ;
    rdfs:label "Jordan Kim (Global HR Ops)" .
<https://acme.example/person/maria-rossi> a prov:Person ;
    rdfs:label "Maria Rossi (Global HR Ops)" .
<https://acme.example/agent/llm-mapper-v2> a prov:SoftwareAgent ;
    rdfs:label "LLM Mapper v2 (acme-internal)" .


# =============================================================================
#  AcmeUK mappings
# =============================================================================

acmeUK:SoftwareEngineer        skos:closeMatch acmeG:SoftwareEngineerL3 .
mapAct:uk_001 a acme:MappingActivity ;
    prov:used acmeUK:SoftwareEngineer ;
    prov:generated acmeG:SoftwareEngineerL3 ;
    prov:wasAssociatedWith <https://acme.example/agent/llm-mapper-v2> ,
                            <https://acme.example/person/jordan-kim> ;
    prov:atTime "2026-03-10T09:00:00Z"^^xsd:dateTime ;
    acme:mappingMethod "LLM-drafted, human-approved" ;
    acme:confidence "0.95"^^xsd:decimal ;
    acme:reviewStatus "approved" .

