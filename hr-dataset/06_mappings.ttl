# Principal SWE is narrower than the L5 staff role (it's higher seniority than L5).
# We model it as a closeMatch to a hypothetical L6+ — but to avoid expanding the
# global catalog here, we use broadMatch to indicate the global concept is broader.
acmeUS:PrincipalSWE      skos:broadMatch acmeG:SoftwareEngineerL5 .
mapAct:us_004 a acme:MappingActivity ;
    prov:used acmeUS:PrincipalSWE ;
    prov:generated acmeG:SoftwareEngineerL5 ;
    prov:wasAssociatedWith <https://acme.example/person/jordan-kim> ;
    prov:atTime "2026-03-13T14:03:00Z"^^xsd:dateTime ;
    acme:mappingMethod "manual" ;
    acme:confidence "0.78"^^xsd:decimal ;
    acme:reviewStatus "approved" .

