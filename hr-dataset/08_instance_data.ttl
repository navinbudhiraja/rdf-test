# =============================================================================
# Instance data: organizations, posts, people, memberships
#
# ~40 employees distributed across the three subsidiaries. Memberships use
# the W3C ORG n-ary pattern: org:Membership reifies the relationship between
# a person, an organization, a role, and (via acme:viaPost) a specific Post,
# bounded by a time interval.
#
# Includes:
#   - reporting lines via org:reportsTo on Posts
#   - one open Post with no current membership (eve_05)
#   - one historical membership with a memberDuring/hasEnd date
# =============================================================================

@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .
@prefix org:    <http://www.w3.org/ns/org#> .
@prefix foaf:   <http://xmlns.com/foaf/0.1/> .
@prefix time:   <http://www.w3.org/2006/time#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix acme:   <https://acme.example/ontology/> .
@prefix acmeUK: <https://acme.example/uk/role/> .
@prefix acmeDE: <https://acme.example/de/role/> .
@prefix acmeUS: <https://acme.example/us/role/> .

@prefix orgU:   <https://acme.example/org/> .
@prefix p:      <https://acme.example/person/> .
@prefix post:   <https://acme.example/post/> .
@prefix m:      <https://acme.example/membership/> .

# -----------------------------------------------------------------------------
# Organizations
# -----------------------------------------------------------------------------

orgU:AcmeGroup  a org:FormalOrganization ;
    skos:prefLabel "Acme Group plc"@en .

orgU:AcmeUK  a acme:Subsidiary ;
    skos:prefLabel "Acme UK Ltd"@en-GB ;
    org:subOrganizationOf orgU:AcmeGroup .

orgU:AcmeDE  a acme:Subsidiary ;
    skos:prefLabel "Acme Deutschland GmbH"@de , "Acme Germany GmbH"@en ;
    org:subOrganizationOf orgU:AcmeGroup .

orgU:AcmeUS  a acme:Subsidiary ;
    skos:prefLabel "Acme USA Inc."@en-US ;
    org:subOrganizationOf orgU:AcmeGroup .

# -----------------------------------------------------------------------------
# AcmeUK people, posts, memberships (~13 employees)
# -----------------------------------------------------------------------------

# Alice Chen - Senior SWE - London Payments team
p:alice_01 a foaf:Person ; foaf:name "Alice Chen" ;
    org:hasMembership m:alice_01 .
post:uk_001 a org:Post ;
    skos:prefLabel "Senior SWE, London Payments"@en-GB ;
    org:role acmeUK:SeniorSoftwareEngineer ;
    org:postIn orgU:AcmeUK ;
    org:reportsTo post:uk_005 .
m:alice_01 a org:Membership ;
    org:member p:alice_01 ;
    org:organization orgU:AcmeUK ;
    org:role acmeUK:SeniorSoftwareEngineer ;
    acme:viaPost post:uk_001 ;
    org:memberDuring [ a time:Interval ;
        time:hasBeginning [ time:inXSDDate "2022-09-01"^^xsd:date ] ] .

