acmeG:ProductManagerL4 a acme:GlobalRole ;
    skos:inScheme acme:GlobalRoleScheme ;
    skos:prefLabel "Product Manager, Level 4"@en ;
    skos:definition "Owns the roadmap for one product area."@en ;
    acme:hasJobFamily acme:Family_Product ;
    acme:hasSeniorityLevel acme:L4 .

acmeG:SeniorProductManagerL5 a acme:GlobalRole ;
